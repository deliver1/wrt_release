# ==========================================
# 1. 目标设备配置 (红米 AX6)
# ==========================================
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_ALL_PROFILES=n
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# 明确指定 AX6 的两个版本 
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_redmi_ax6=y
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_redmi_ax6-stock=y

# ==========================================
# 2. 基础内核模块
# ==========================================
CONFIG_PACKAGE_kmod-netlink-diag=y
CONFIG_PACKAGE_kmod-inet-diag=y
CONFIG_PACKAGE_kmod-tls=y
CONFIG_PACKAGE_kmod-tun=y

# ==========================================
# 3. 基础工具包 (网络与管理)
# ==========================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_openssl-util=y
CONFIG_PACKAGE_qrencode=y
CONFIG_PACKAGE_mii-tool=y

# ==========================================
# 4. 内存优化与防崩溃 
# ==========================================
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_earlyoom=y

# ==========================================
# 5. LuCI 插件与应用
# ==========================================
# 基础功能
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_PACKAGE_luci-app-sqm=y
CONFIG_PACKAGE_luci-i18n-sqm-zh-cn=y

# 核心代理插件 (极致精简，只留 Nikki)
CONFIG_PACKAGE_luci-app-nikki=y
CONFIG_PACKAGE_luci-i18n-nikki-zh-cn=y

# ==========================================
# 6. [强制禁用] 无线 Wi-Fi 相关 
# ==========================================
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq8074=n
CONFIG_PACKAGE_ath11k-firmware-qca9074=n
CONFIG_PACKAGE_kmod-ath10k=n
CONFIG_PACKAGE_kmod-ath10k-smallbuffers=n
CONFIG_PACKAGE_ath10k-firmware-qca9887=n
CONFIG_PACKAGE_wpad-openssl=n
CONFIG_PACKAGE_wpad-basic=n
CONFIG_PACKAGE_wpad-mini=n
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_iw=n

# ==========================================
# 7. 编译错误修复补丁 (绕过 GCC 14 严格检查)
# ==========================================
CONFIG_PKG_FORTIFY_SOURCE_NONE=y
# CONFIG_PKG_FORTIFY_SOURCE_1 is not set
# CONFIG_PKG_FORTIFY_SOURCE_2 is not set
CONFIG_EXTRA_OPTIMIZATION="-fno-caller-saves -fno-plt -Wno-error=format-nonliteral"
